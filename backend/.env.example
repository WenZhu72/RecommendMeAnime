# Local development defaults. Do not commit backend/.env.
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/recommend_me_anime
ANILIST_API_URL=https://graphql.anilist.co
EXTERNAL_API_TIMEOUT_SECONDS=10
CACHE_TTL_SECONDS=3600
EXACT_PAGINATION_CACHE_TTL_SECONDS=3600
ANILIST_EXACT_PROBE_RESPONSE_WAIT_SECONDS=3
ANILIST_EXACT_PROBE_MAX_PAGE=250
ANILIST_STALE_IF_ERROR_SECONDS=3600
ANILIST_MAX_CONCURRENCY=4
ANILIST_MAX_RETRIES=1
ANILIST_RETRY_FALLBACK_SECONDS=1
ANILIST_MAX_RETRY_DELAY_SECONDS=30
PAGINATION_FRESH_HOURS=24
PAGINATION_VERY_STALE_DAYS=7
PAGINATION_PROBE_TIMEOUT_SECONDS=15
PAGINATION_MAX_CONCURRENT_PROBES=2
PAGINATION_RETRY_BACKOFF_SECONDS=300,900,3600,21600
BROWSE_CACHE_MAX_ENTRIES=256
BROWSE_CACHE_HOT_PAGE_TTL_SECONDS=3600
BROWSE_CACHE_WARM_PAGE_TTL_SECONDS=1800
BROWSE_CACHE_COLD_PAGE_TTL_SECONDS=600
BROWSE_CACHE_HOT_ACCESS_THRESHOLD=5
LOG_LEVEL=INFO

# Comma-separated browser origins. Add the deployed Vercel URL in Render.
CORS_ALLOWED_ORIGINS=http://localhost:3000
