# Local development defaults. Do not commit backend/.env.
APP_ENV=development
ANILIST_API_URL=https://graphql.anilist.co
EXTERNAL_API_TIMEOUT_SECONDS=10
CACHE_TTL_SECONDS=3600
LOG_LEVEL=INFO

# Comma-separated browser origins. Add the deployed Vercel URL in Render.
CORS_ALLOWED_ORIGINS=http://localhost:3000
